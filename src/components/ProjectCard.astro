---
export interface Props {
  title: string;
  status: string;
  description: string;
  icon: string;
}

const { title, status, description, icon } = Astro.props;
---

<div
  class="group relative flex flex-col gap-2 rounded-lg border border-gray-100 dark:border-neutral-800 bg-white dark:bg-neutral-900 shadow-sm transition-all duration-200 hover:shadow-md hover:border-gray-200 dark:hover:border-neutral-700 overflow-hidden"
>
  <div
    class="aspect-video flex items-center justify-center bg-gray-50 dark:bg-neutral-800/50"
  >
    <span
      class="text-4xl font-bold text-gray-200 dark:text-neutral-700 select-none"
    >
      {icon}
    </span>
  </div>
  <div class="flex flex-col gap-2 p-4 pt-3">
    <div class="flex items-start justify-between">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-neutral-100">{title}</h3>
      <span
        class="inline-flex items-center px-2 py-0.5 text-xs text-gray-400 dark:text-neutral-500 bg-gray-50 dark:bg-neutral-800 border border-gray-100 dark:border-neutral-700 rounded-full shrink-0 ml-2"
      >
        {status}
      </span>
    </div>
    <p class="text-xs text-gray-500 dark:text-neutral-400 leading-relaxed">{description}</p>
  </div>
</div>
