---
import Badge from "./Badge.astro";

export interface Props {
  name: string;
  description: string;
  stars: number;
  language: string;
  url: string;
}

const { name, description, stars, language, url } = Astro.props;
---

<div class="relative pl-5 pb-6 border-l border-gray-200 dark:border-neutral-800 last:pb-0">
  <div
    class="absolute left-0 top-1.5 w-2 h-2 -translate-x-1/2 rounded-full bg-gray-400 dark:bg-neutral-500 ring-2 ring-white dark:ring-neutral-950"
  />
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-1">
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm font-semibold text-gray-900 dark:text-neutral-100 hover:underline"
    >
      {name}
      <svg
        class="inline-block w-3 h-3 ml-1 -mt-0.5 text-gray-400 dark:text-neutral-500"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
        />
      </svg>
    </a>
    <div class="flex items-center gap-3 text-xs text-gray-400 dark:text-neutral-500">
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
        {stars.toLocaleString()}
      </span>
      <Badge name={language} />
    </div>
  </div>
  <p class="text-sm text-gray-600 dark:text-neutral-400 leading-relaxed">{description}</p>
</div>
