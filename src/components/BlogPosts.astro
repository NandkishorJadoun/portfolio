---
import SectionHeading from "./SectionHeading.astro";
import { blogPosts } from "../data/site";
---

<section class="py-10 md:py-14">
  <SectionHeading label="Writing" title="Articles and thoughts" />
  <div class="divide-y divide-gray-100 dark:divide-neutral-800">
    {blogPosts.map((post) => (
      <div class="flex items-center justify-between py-2.5 first:pt-0">
        <span class="text-sm font-medium text-gray-900 dark:text-neutral-100">{post.title}</span>
        <span class="text-xs text-gray-400 dark:text-neutral-500 shrink-0 ml-4">{post.source}</span>
      </div>
    ))}
  </div>
</section>
