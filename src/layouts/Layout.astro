---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>Alex Chen — Portfolio</title>
    <meta
      name="description"
      content="Full-stack developer and UI architect building thoughtful web applications."
    />
    <script is:inline>
      (function () {
        var theme = localStorage.getItem("theme");
        if (
          theme === "dark" ||
          (!theme &&
            window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body
    class="bg-white dark:bg-neutral-950 text-gray-900 dark:text-neutral-100 font-sans antialiased transition-colors duration-200"
  >
    <slot />
  </body>
</html>
